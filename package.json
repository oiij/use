{
  "name": "@oiij/use",
  "type": "module",
  "version": "0.0.12",
  "description": "",
  "author": "oiij",
  "license": "MIT",
  "homepage": "https://github.com/oiij/use",
  "repository": {
    "type": "git",
    "url": "git@github.com:oiij/use.git"
  },
  "bugs": "https://github.com/oiij/use/issues",
  "keywords": [
    "@oiij/use"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./class": {
      "types": "./dist/class.d.ts",
      "import": "./dist/class.js",
      "require": "./dist/class.cjs"
    },
    "./addons/ai-editor": {
      "types": "./dist/addons/ai-editor.d.ts",
      "import": "./dist/addons/ai-editor.js",
      "require": "./dist/addons/ai-editor.cjs"
    },
    "./addons/e-charts": {
      "types": "./dist/addons/e-charts.d.ts",
      "import": "./dist/addons/e-charts.js",
      "require": "./dist/addons/e-charts.cjs"
    },
    "./addons/emoji-picker": {
      "types": "./dist/addons/emoji-picker.d.ts",
      "import": "./dist/addons/emoji-picker.js",
      "require": "./dist/addons/emoji-picker.cjs"
    },
    "./addons/markdown-it": {
      "types": "./dist/addons/markdown-it.d.ts",
      "import": "./dist/addons/markdown-it.js",
      "require": "./dist/addons/markdown-it.cjs"
    },
    "./addons/shiki": {
      "types": "./dist/addons/shiki.d.ts",
      "import": "./dist/addons/shiki.js",
      "require": "./dist/addons/shiki.cjs"
    },
    "./addons/three-js": {
      "types": "./dist/addons/three-js.d.ts",
      "import": "./dist/addons/three-js.js",
      "require": "./dist/addons/three-js.cjs"
    },
    "./addons/tiptap": {
      "types": "./dist/addons/tiptap.d.ts",
      "import": "./dist/addons/tiptap.js",
      "require": "./dist/addons/tiptap.cjs"
    },
    "./addons/v-charts": {
      "types": "./dist/addons/v-charts.d.ts",
      "import": "./dist/addons/v-charts.js",
      "require": "./dist/addons/v-charts.cjs"
    },
    "./addons/xlsx": {
      "types": "./dist/addons/xlsx.d.ts",
      "import": "./dist/addons/xlsx.js",
      "require": "./dist/addons/xlsx.cjs"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "README.md",
    "dist",
    "package.json"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "dev:unbuild": "unbuild --stub",
    "build": "tsc --noEmit && tsup",
    "build:unbuild": "tsc --noEmit && unbuild",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepublishOnly": "pnpm build",
    "release": "bumpp -r && npm publish --access public",
    "awe": "pnpx are-we-esm",
    "nmi": "pnpx node-modules-inspector",
    "start": "esno src/index.ts",
    "test": "vitest",
    "update:deps": "taze -w && pnpm i",
    "type:check": "tsc --noEmit",
    "cz": "czg",
    "commit": "git pull && git add -A && pnpm cz && git push",
    "link": "pnpm link --global",
    "preinstall": "npx only-allow pnpm"
  },
  "peerDependencies": {
    "@emoji-mart/data": "^1.2.1",
    "@tiptap/core": "^2.11.7",
    "@tiptap/pm": "^2.11.7",
    "@tiptap/starter-kit": "^2.11.7",
    "@tweakpane/core": "^2.0.5",
    "@tweakpane/plugin-essentials": "^0.2.1",
    "@visactor/vchart": "^1.13.8",
    "@vueuse/core": "^13.1.0",
    "aieditor": "^1.3.6",
    "echarts": "^5.6.0",
    "emoji-mart": "^5.6.0",
    "file-saver": "^2.0.5",
    "markdown-it": "^14.1.0",
    "postprocessing": "^6.37.2",
    "shiki": "^3.2.2",
    "three": "^0.175.0",
    "tweakpane": "^4.0.5",
    "vue": "^3.5.13",
    "xlsx": "^0.18.5"
  },
  "dependencies": {
    "@oiij/utils": "^0.0.1",
    "mitt": "^3.0.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.12.0",
    "@emoji-mart/data": "^1.2.1",
    "@oiij/tsconfig": "^0.0.1",
    "@tiptap/core": "^2.11.7",
    "@tiptap/pm": "^2.11.7",
    "@tiptap/starter-kit": "^2.11.7",
    "@tweakpane/core": "^2.0.5",
    "@tweakpane/plugin-essentials": "^0.2.1",
    "@types/file-saver": "^2.0.7",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.14.1",
    "@types/three": "^0.175.0",
    "@visactor/vchart": "^1.13.8",
    "@vitest/ui": "^3.1.1",
    "@vueuse/core": "^13.1.0",
    "aieditor": "^1.3.6",
    "bumpp": "^10.1.0",
    "commitlint": "^19.8.0",
    "cz-git": "^1.11.1",
    "czg": "^1.11.1",
    "echarts": "^5.6.0",
    "emoji-mart": "^5.6.0",
    "eslint": "^9.24.0",
    "eslint-plugin-format": "^1.0.1",
    "esno": "^4.8.0",
    "file-saver": "^2.0.5",
    "lint-staged": "^15.5.1",
    "markdown-it": "^14.1.0",
    "postprocessing": "^6.37.2",
    "shiki": "^3.2.2",
    "simple-git-hooks": "^2.12.1",
    "taze": "^19.0.4",
    "three": "^0.175.0",
    "tsup": "^8.3.6",
    "tweakpane": "^4.0.5",
    "typescript": "^5.8.3",
    "unbuild": "^3.5.0",
    "vitest": "^3.1.1",
    "vue": "^3.5.13",
    "xlsx": "^0.18.5"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged && pnpm type:check"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "pnpm lint:fix"
    ]
  },
  "publishConfig": {
    "access": "public"
  }
}
