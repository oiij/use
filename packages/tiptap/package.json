{
  "name": "@oiij/tiptap",
  "type": "module",
  "version": "0.0.16",
  "description": "A Vue Composable for Tiptap",
  "author": "oiij",
  "license": "MIT",
  "homepage": "https://github.com/oiij/use",
  "repository": {
    "type": "git",
    "url": "git@github.com:oiij/use.git"
  },
  "bugs": "https://github.com/oiij/use/issues",
  "keywords": [
    "@oiij/use",
    "tiptap"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style": {
      "import": "./dist/style.css"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "LICENSE",
    "README.md",
    "dist",
    "package.json"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "build": "vue-tsc --noEmit && tsdown",
    "bumpp": "bumpp --no-push",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "@tiptap/core": "catalog:pkg",
    "@tiptap/extension-image": "catalog:pkg",
    "@tiptap/pm": "catalog:pkg",
    "@tiptap/starter-kit": "catalog:pkg",
    "@vueuse/core": "catalog:pkg",
    "vue": "catalog:pkg"
  },
  "devDependencies": {
    "@tiptap/core": "catalog:pkg",
    "@tiptap/extension-image": "catalog:pkg",
    "@tiptap/pm": "catalog:pkg",
    "@tiptap/starter-kit": "catalog:pkg",
    "@vueuse/core": "catalog:pkg",
    "vue": "catalog:pkg"
  },
  "publishConfig": {
    "access": "public"
  }
}
